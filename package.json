{
  "name": "cloakgate-monorepo",
  "version": "1.0.0",
  "description": "Clash 订阅分发服务 - Monorepo版本，支持JavaScript和Rust实现",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:js": "npm run dev --workspace=javascript-package",
    "dev:rust": "cargo run -p rust-package",
    "devs": "concurrently \"npm:dev:*\"",
    "start:js": "npm run start --workspace=javascript-package",
    "start:rust": "cargo run -p rust-package --release",
    "build": "echo 'JavaScript版本无需构建，Rust版本使用cargo build'",
    "test": "npm run test --workspaces && cargo check",
    "clean": "npm run clean --workspaces && cargo clean -p rust-package",
    "docker:build:js": "docker build -f packages/javascript-package/Dockerfile -t cloakgate:js .",
    "docker:build:rust": "docker build -f packages/rust-package/Dockerfile -t cloakgate:rust .",
    "install:all": "npm install && cargo fetch"
  },
  "keywords": [
    "clash",
    "subscription",
    "proxy",
    "monorepo",
    "javascript",
    "rust"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
