# CloakGate 环境配置文件示例
# 复制此文件为 .env 并根据实际环境修改
# cp .env.example .env

# ----------------------------
# 基础配置
# ----------------------------

# 服务端口
PORT=3000
APP_PORT=3000

# API 域名（用于生成订阅中的 provider URL）
API_DOMAIN=https://api.starying.top

# ----------------------------
# 3X-UI / Xray 面板配置
# ----------------------------

# 面板 IP 地址 (如果是本机部署通常为 127.0.0.1)
XUI_HOST=127.0.0.1

# 面板端口
XUI_PORT=54321

# 面板 Web 根路径 (如果有设置，例如 /xui)
XUI_WEB_BASE_PATH=/mEoDlubA1d4mISPXpQ

# 面板用户名
XUI_USERNAME=

# 面板密码
XUI_PASSWORD=

# ----------------------------
# IP 阻断服务配置
# ----------------------------

# 是否启用 IP 阻断功能 (true/false)
IP_BLOCKER_ENABLED=false

# 检查轮询间隔 (毫秒)
IP_BLOCKER_POLL_INTERVAL=30000

# 每次获取日志的条数
IP_BLOCKER_LOG_COUNT=50

# Fail2Ban Jail 名称 (通常为 sshd 或 3x-ipl 等)
IP_BLOCKER_JAIL_NAME=3x-ipl

# 是否仅模拟运行 (true: 仅打印日志不执行阻断, false: 实际执行阻断)
# 建议首次部署时开启测试，确认无误后关闭
IP_BLOCKER_DRY_RUN=true

# ----------------------------
# IP 清理配置
# ----------------------------

# 不活跃 IP 清理阈值（天数）
# 当某个 IP 超过指定天数未发送请求时，会被自动清理以腾出空位
# 默认: 7 天
IP_CLEANUP_INACTIVE_DAYS=7
