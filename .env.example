# sublinker 环境配置文件示例
# 复制此文件为 .env 并根据实际环境修改
# cp .env.example .env

# ----------------------------
# 基础配置
# ----------------------------

# 服务端口
PORT=3000

# SQLite 数据库路径（建议放在项目根目录 data 下）
# 示例：DB_PATH=/opt/sublinker/data/sublinker.db
DB_PATH=

# 日志级别（error|warn|info|debug）
LOG_LEVEL=info

# 可信代理 IP（逗号分隔，仅这些直连 IP 才信任 X-Forwarded-For / X-Real-IP）
# 示例: 127.0.0.1,::1,10.0.0.0/8
TRUSTED_PROXIES=127.0.0.1,::1

# CORS 允许的来源（默认 * 允许所有来源，生产环境应配置为前端域名）
# 示例: https://admin.example.com
CORS_ORIGIN=*

# ----------------------------
# 认证配置（必填）
# ----------------------------

# 初始管理员账号（仅在数据库无管理员时生效）
ADMIN_USERNAME=replaceWithYourAdminUsername
ADMIN_PASSWORD=replaceWithYourAdminPassword

# JWT 密钥（务必使用高强度随机字符串）
JWT_SECRET=replaceWithLongRandomSecret

# JWT 过期时间（示例：24h、7d）
JWT_EXPIRES_IN=24h
