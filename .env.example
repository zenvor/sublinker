# 管理员登录用户名（仅在首次初始化数据库时写入）；示例：admin
ADMIN_USERNAME=admin

# 管理员登录密码（仅在首次初始化数据库时写入）；示例：ChangeMe123!@#
ADMIN_PASSWORD=ChangeMe123!@#

# JWT 签名密钥（必须使用高强度随机字符串）
# 生成示例：openssl rand -hex 32
JWT_SECRET=please_replace_with_random_string

# JWT 过期时间（jsonwebtoken 格式）；示例：24h
JWT_EXPIRES_IN=24h

# 后端服务监听端口；示例：3000
PORT=3000

# 可信代理来源（逗号分隔的 IP/CIDR）；示例：127.0.0.1,::1
TRUSTED_PROXIES=127.0.0.1,::1

# CORS 允许来源（开发可用 *，生产建议填前端域名）；示例：https://panel.example.com
CORS_ORIGIN=*

# 日志级别（error|warn|info|debug）；示例：info
LOG_LEVEL=info
